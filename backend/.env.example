# Django Settings
SECRET_KEY=generate-a-secure-secret-key-here
DEBUG=False
ALLOWED_HOSTS=.yourdomain.com
TIME_ZONE=Asia/Kathmandu
FRONTEND_URL=https://yourdomain.com

# Database (PostgreSQL recommended for production)
DATABASE_URL=postgresql://user:password@localhost:5432/elearning

# CORS
CORS_ALLOWED_ORIGINS=https://yourdomain.com
CORS_ALLOWED_ORIGIN_REGEXES=
CSRF_TRUSTED_ORIGINS=https://yourdomain.com
MAX_PAGE_SIZE=100

# Tenant Header Trust
TENANT_HEADER_TRUST_MODE=never
BILLING_LEGACY_SUNSET=2026-12-31
PRIMARY_PUBLIC_DOMAIN=yourdomain.com
PUBLIC_DOMAINS=yourdomain.com,www.yourdomain.com,school1.yourdomain.com,school2.yourdomain.com

# JWT Policy (Role-aware lifetimes + strict rotation)
JWT_ACCESS_MINUTES_DEFAULT=60
JWT_REFRESH_DAYS_DEFAULT=7
JWT_ACCESS_MINUTES_SAAS_ADMIN=15
JWT_REFRESH_DAYS_SAAS_ADMIN=1
JWT_ACCESS_MINUTES_ADMIN=20
JWT_REFRESH_DAYS_ADMIN=2
JWT_STRICT_REFRESH_ROTATION=true

# Security Headers / CSP
CSP_REPORT_ONLY=false
CSP_CONNECT_SRC_EXTRA=
SECURITY_PERMISSIONS_POLICY=camera=(), microphone=(), geolocation=()
SECURE_SSL_REDIRECT=true
SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO,https
USE_X_FORWARDED_HOST=true
SECURE_HSTS_SECONDS=2592000
SECURE_HSTS_INCLUDE_SUBDOMAINS=true

# Observability
LOG_LEVEL=INFO
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.05

# Async Workers (Celery + Redis)
REDIS_URL=redis://localhost:6379/1
ASYNC_TASK_BACKEND=celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_STORE_EAGER_RESULT=true
ASYNC_JOB_STATUS_TTL_SECONDS=86400

# Email (SMTP)
# Generic SMTP:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.your-provider.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@example.com
# EMAIL_HOST_PASSWORD=your-app-password
#
# Resend API backend:
EMAIL_BACKEND=core.email_backends.resend_backend.ResendAPIEmailBackend
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_API_URL=https://api.resend.com/emails
RESEND_REQUEST_TIMEOUT=10

# Optional: Postmark SMTP alternative
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.postmarkapp.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False
# EMAIL_HOST_USER=your-postmark-server-token
# EMAIL_HOST_PASSWORD=your-postmark-server-token

DEFAULT_FROM_EMAIL=noreply@your-verified-domain.com
SERVER_EMAIL=noreply@your-verified-domain.com
EMAIL_TIMEOUT=10

# AI Services
OPENAI_API_KEY=your-openai-api-key
AI_EMBEDDING_MODEL=text-embedding-3-small
AI_EMBEDDING_DIMENSIONS=1536
AI_CONTENT_CHUNK_WORDS=180
AI_CONTENT_CHUNK_OVERLAP_WORDS=30
AI_TUTOR_TOP_K=5
AI_TUTOR_MIN_SIMILARITY=0.58
# Mask PII (email/phone/long IDs) in prompts before they reach third-party LLMs.
# Defaults true; set false only for trusted/self-hosted providers.
AI_PII_REDACTION=true
THROTTLE_AI_TUTOR_CHAT=30/min
AI_RISK_LOOKBACK_DAYS=30
AI_RISK_INACTIVITY_DAYS=14
AI_AT_RISK_NOTIFICATION_THRESHOLD=75
AI_AT_RISK_MIN_SCORE=40
AI_RISK_USE_LLM_EXPLANATIONS=false
AI_ADMIN_ASSISTANT_LOOKBACK_DAYS=30
AI_ADMIN_ASSISTANT_USE_LLM_CLASSIFIER=false
AI_ADMIN_ASSISTANT_USE_LLM_RESPONSE=false

# Security
SNYK_TOKEN=your-snyk-token
