# ─── Playwright / E2E QA Environment ──────────────────────────────────────────
# Copy this file to .env.local (gitignored) and fill in your values.
# .env.local is loaded automatically by playwright.config.ts via dotenv.

# Base URLs ────────────────────────────────────────────────────────────────────
# API backend (Django). Set to production URL when running against prod.
E2E_API_URL=https://demo.manyaltech.com

# Frontend Next.js URL. Required for 11-frontend-auth and 12-frontend-dashboards.
E2E_BASE_URL=https://demo.manyaltech.com

# Tenant slug used for all QA API calls and login forms.
E2E_QA_TENANT=demo

# ─── Role Credentials ─────────────────────────────────────────────────────────
# These users must exist in the tenant above.
E2E_ADMIN_EMAIL=admin@demo.school
E2E_ADMIN_PASS=ReplaceWithRealPassword

E2E_STAFF_EMAIL=staff1@demo.school
E2E_STAFF_PASS=ReplaceWithRealPassword

E2E_TEACHER_EMAIL=teacher1@demo.school
E2E_TEACHER_PASS=ReplaceWithRealPassword

E2E_STUDENT_EMAIL=student2@demo.school
E2E_STUDENT_PASS=ReplaceWithRealPassword

E2E_PARENT_EMAIL=parent.13@demo.school.edu
E2E_PARENT_PASS=ReplaceWithRealPassword
