{
  "name": "e-learningwebapp",
  "version": "1.0.0",
  "description": "[![License](https://img.shields.io/badge/license-MIT-blue.svg)](LICENSE) [![Django](https://img.shields.io/badge/Django-5.1-green.svg)](https://www.djangoproject.com/) [![Next.js](https://img.shields.io/badge/Next.js-14-black.svg)](https://nextjs.org/) [![TypeScript](https://img.shields.io/badge/TypeScript-5.0-blue.svg)](https://www.typescriptlang.org/)",
  "main": "index.js",
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test:e2e": "playwright test",
    "test:e2e:critical": "playwright test tests/e2e/critical/lms-critical.spec.ts",
    "test:e2e:smoke": "playwright test tests/e2e/smoke",
    "test:e2e:scale": "playwright test tests/e2e/critical/lms-deployed-scale.spec.ts",
    "test:qa": "playwright test --config=tests/qa.config.ts --project=chromium",
    "test:qa:auth": "playwright test --config=tests/qa.config.ts tests/e2e/qa/01-auth.spec.ts",
    "test:qa:admin": "playwright test --config=tests/qa.config.ts tests/e2e/qa/02-admin-crud.spec.ts",
    "test:qa:teacher": "playwright test --config=tests/qa.config.ts tests/e2e/qa/03-teacher-crud.spec.ts",
    "test:qa:student": "playwright test --config=tests/qa.config.ts tests/e2e/qa/04-student-flows.spec.ts",
    "test:qa:library": "playwright test --config=tests/qa.config.ts tests/e2e/qa/05-library.spec.ts",
    "test:qa:health": "playwright test --config=tests/qa.config.ts tests/e2e/qa/10-api-health.spec.ts",
    "test:qa:gamification": "playwright test --config=tests/qa.config.ts tests/e2e/qa/14-gamification-admin.spec.ts",
    "test:qa:fees": "playwright test --config=tests/qa.config.ts tests/e2e/qa/15-fees-billing.spec.ts",
    "test:qa:full": "bash scripts/run-qa.sh",
    "test:qa:prod": "bash scripts/run-qa.sh --prod",
    "api:types": "bash scripts/generate-openapi-types.sh"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "dotenv": "^17.4.1"
  },
  "dependencies": {
    "react-dom": "^19.2.4",
    "react-native-web": "^0.21.2"
  }
}
